# Partner Portal local environment template
# Copy this file to .env.development (or .env.local) and update values as needed.
# Do not commit sensitive values.

# Auth mode
# Legacy and VITE aliases are both supported during migration.
USE_MOCK_AUTH=true
VITE_USE_MOCKED_AUTH=true

# Mock data mode
# Keep true for local development without backend containers.
USE_MOCK_DATA=true
VITE_USE_MOCKED_DATA=true

# Mock data scale presets: small | 10k | 100k | 1m
# This preset represents total generated records across all domains.
MOCK_DATA_SCALE=small
VITE_MOCK_DATA_SCALE=small

# Seed controls deterministic generation for repeatable local tests.
MOCK_DATA_SEED=42
VITE_MOCK_DATA_SEED=42

# Azure AD application registration (required when USE_MOCK_AUTH=false)
MSAL_CLIENT_ID=your-app-registration-client-id
MSAL_TENANT_ID=your-azure-ad-tenant-id
MSAL_REDIRECT_URI=http://localhost:4200
API_SCOPE=api://partner-portal/.default

# API
API_BASE_URL=http://localhost:5000/api
VITE_API_BASE_URL=http://localhost:5000/api

# Tenant runtime context (used for tenant headers)
TENANT_ID=tenant-accenture-demo
VITE_TENANT_ID=tenant-accenture-demo

# Optional comma-separated feature flags propagated in X-Feature-Flags
FEATURE_FLAGS=
VITE_FEATURE_FLAGS=

# Optional app identity values for downstream tooling/documentation
VITE_COMPANY_NAME=Accenture
VITE_UI_NAME=Oscar Application
VITE_PRODUCT_FULL_NAME=Accenture Risk and Compliance

# Module Federation remote URLs (local defaults)
REMOTE_RISK_URL=http://localhost:4201/remoteEntry.js
REMOTE_COMPLIANCE_URL=http://localhost:4202/remoteEntry.js
REMOTE_AUDIT_URL=http://localhost:4203/remoteEntry.js
REMOTE_POLICY_URL=http://localhost:4204/remoteEntry.js
REMOTE_INCIDENTS_URL=http://localhost:4205/remoteEntry.js
REMOTE_VENDOR_URL=http://localhost:4206/remoteEntry.js
REMOTE_ONBOARDING_URL=http://localhost:4207/remoteEntry.js
