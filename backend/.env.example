# Generated by GitHub Copilot
# Backend environment template for local development.

PORT=5000
DATABASE_URL=postgres://partner_portal:partner_portal_dev@127.0.0.1:5433/partner_portal
CORS_ORIGIN=http://localhost:4200,http://127.0.0.1:4200

# Seed the database automatically if domain tables are empty.
AUTO_SEED=true
AUTO_SEED_PRESET=small

# Real-time simulator updates random records and emits SSE events.
ENABLE_REALTIME_SIMULATOR=true
REALTIME_TICK_MS=12000

# Prevents accidental out-of-memory bulk generation on local machines.
MAX_RECORDS_PER_DOMAIN=100000
BULK_LOAD_PRESET=10k
BULK_LOAD_SEED=42

# Worker and internal service settings
API_BASE_URL=http://localhost:5000/api
BULK_LOAD_API_BASE=http://localhost:5000/api

# Generated by scripts: keys:master and keys:dev
SECRETS_MASTER_KEY=
DEV_API_KEY_DEFAULT=
DEV_API_KEY_SYSTEM=
