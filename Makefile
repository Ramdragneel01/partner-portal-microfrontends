# One-time setup
bootstrap:
	$(call check_node_modules,bootstrap)
	$(call check_env,bootstrap)
	@echo "[bootstrap] Done. Next: make run"

# Verify local prerequisites for this workspace
env-check:
	@command -v node >/dev/null 2>&1 || (echo "[env-check] ERROR: node is required" && exit 1)
	@command -v npm >/dev/null 2>&1 || (echo "[env-check] ERROR: npm is required" && exit 1)
	@node -e "console.log('[env-check] Node ' + process.version)"
	$(call check_env,env-check)
	@echo "[env-check] Checking repo-owned dev listeners on ports 4200-4207"
	@$(PORT_CLEANER)
	@echo "[env-check] Environment looks good"

# Start shell + all remotes (full modernization stack)
run:
	$(call check_node_modules,run)
	$(call check_env,run)
	@echo "[run] Freeing stale local dev ports..."
	@$(PORT_CLEANER)
	@echo "[run] Starting shell + all micro-apps for full portal flow"
	@$(LOAD_ENV); $(NX_RUNNER) run-many --target=serve --projects=$(ALL_APPS) --parallel=8

# Start with Azure auth enabled (mock auth disabled)
run-ms-auth:
	$(call check_node_modules,run-ms-auth)
	$(call check_env,run-ms-auth)
	$(call check_ms_auth_env,run-ms-auth)
	@echo "[run-ms-auth] Freeing stale local dev ports..."
	@$(PORT_CLEANER)
	@echo "[run-ms-auth] Starting shell + remotes with Azure auth"
	@$(LOAD_ENV); USE_MOCK_AUTH=false VITE_USE_MOCKED_AUTH=false $(NX_RUNNER) run-many --target=serve --projects=$(ALL_APPS) --parallel=8

# Keep legacy naming familiar for teams migrating from monolith tooling
all-in-one: run

# Backend API local run (without containers)
backend:
	@echo "[backend] Ensuring backend dependencies"
	@cd backend && if [ ! -d node_modules ]; then npm install; fi
	@echo "[backend] Ensuring backend environment file"
	@cd backend && if [ ! -f .env ]; then cp .env.example .env; fi
	@cd backend && node -e "const fs=require('node:fs');const file='.env';if(fs.existsSync(file)){const raw=fs.readFileSync(file,'utf8');const next=raw.replace(/@localhost:/g,'@127.0.0.1:');if(next!==raw){fs.writeFileSync(file,next);console.log('[backend] Updated DATABASE_URL host localhost -> 127.0.0.1');}}"
	@echo "[backend] Starting backend API on http://localhost:5000"
	@cd backend && npm run dev

# Stop local dev listeners started by this repo
down:
	@echo "[down] Stopping repo-owned Nx dev listeners on 4200-4207"
	@$(PORT_CLEANER)

# Clear common build artifacts and reset Nx state
clean:
	@echo "[clean] Cleaning generated artifacts and Nx state"
	@$(PORT_CLEANER)
	@$(NX_RUNNER) reset
	@rm -rf dist .nx/cache

