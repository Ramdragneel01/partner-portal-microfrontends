# Partner Portal Microfrontends - Development Makefile

# Configuration
ENV_FILE ?= .env.development
NX_RUNNER := node ./tools/scripts/run-nx.js
PORT_CLEANER := node ./tools/scripts/prepare-dev-ports.js

ALL_APPS := shell,risk-assessment,compliance-dashboard,audit-management,policy-management,incident-reporting,vendor-risk,partner-onboarding
SECURITY_APPS := shell,risk-assessment,compliance-dashboard,audit-management,policy-management,incident-reporting
LIFECYCLE_APPS := shell,vendor-risk,partner-onboarding

# Load .env file into shell environment for a single recipe line.
LOAD_ENV = set -a; [ -f $(ENV_FILE) ] && . $(ENV_FILE); set +a

UNSUPPORTED_TARGETS := dev-worker dev-logs db-check test-api test-sdk test-shared test-web test-migrations test-bruno test-bruno-system lint-fix openapi-generate branch-validate branch build-sdk obs obs-down obs-clean obs-logs dev-api-key

.PHONY: help bootstrap env-check \
	run run-ms-auth all-in-one backend down clean \
	ui-dev ui-build ui-build-local \
	build build-affected lint lint-affected test test-watch test-coverage type ci graph \
	start-shell start-risk start-compliance start-audit start-policy start-incidents start-vendor start-onboarding \
	risk-compliance-stack vendor-lifecycle-stack full-portal-stack \
	$(UNSUPPORTED_TARGETS)

define check_node_modules
	@if [ ! -d node_modules ]; then \
		echo "[$1] node_modules not found. Installing dependencies..."; \
		npm install --legacy-peer-deps; \
	fi
endef

define check_env
	@if [ ! -f $(ENV_FILE) ]; then \
		if [ -f .env.example ]; then \
			echo "[$1] Creating $(ENV_FILE) from .env.example"; \
			cp .env.example $(ENV_FILE); \
		else \
			echo "[$1] ERROR: Missing $(ENV_FILE) and .env.example"; \
			exit 1; \
		fi; \
	fi
endef

define check_ms_auth_env
	@$(LOAD_ENV); \
	if [ -z "$$MSAL_CLIENT_ID" ] || [ "$$MSAL_CLIENT_ID" = "your-app-registration-client-id" ]; then \
		echo "[$1] ERROR: MSAL_CLIENT_ID is not set in $(ENV_FILE)"; \
		exit 1; \
	fi; \
	if [ -z "$$MSAL_TENANT_ID" ] || [ "$$MSAL_TENANT_ID" = "your-azure-ad-tenant-id" ]; then \
		echo "[$1] ERROR: MSAL_TENANT_ID is not set in $(ENV_FILE)"; \
		exit 1; \
	fi
endef

